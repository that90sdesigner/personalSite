---
import { getCollection, render } from 'astro:content';
import Header from '../../components/header.astro';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/footer.astro';
import '../../styles/blogpost.css';
import '../../styles/global.css'

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}
// 2. For your template, you can get the entry directly from the prop
const { post } = Astro.props;
const { Content } = await render(post);
const postTransitionName = `post-title-${post.id}`;
---

<Layout title={`Shankar • ${post.data.title}`}>
  <main>
    <Header />
    <p class="post-date">
      {post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Unknown Date'}
    </p>
    <h1 style={`view-transition-name: ${postTransitionName};`}>{post.data.title}</h1>
    <Content />
    <Footer />
  </main>
</Layout>
